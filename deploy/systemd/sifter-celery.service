[Unit]
Description=SIFTER Celery Worker
After=network.target redis-server.service

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/data/sifter/app
EnvironmentFile=/data/sifter/env/sifter.env
Environment=UV_CACHE_DIR=/data/sifter/.cache/uv
ExecStart=/usr/local/bin/uv run celery -A sifter_web.celery:app worker --loglevel=INFO
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
